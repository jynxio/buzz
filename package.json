{
    "name": "umbra",
    "type": "module",
    "version": "1.0.0",
    "private": true,
    "scripts": {
        "--------------------------------------------------------@": "Basic",
        "dev": "vite",
        "dev:ui": "pnpm --filter @jynxio/ui dev",
        "build": "tsc -b && vite build",
        "build:ui": "pnpm --filter @jynxio/ui build",
        "preview": "vite preview",
        "--------------------------------------------------------#": "Husky",
        "prepare": "husky",
        "husky:prepush": "pnpm lint:ts",
        "husky:precommit": "lint-staged",
        "husky:commitmsg": "commitlint --edit",
        "--------------------------------------------------------$": "Linter",
        "lint:js": "eslint --fix",
        "lint:ts": "tsc --build --noEmit",
        "lint:style": "prettier --write .",
        "lint:css": "stylelint \"**/*.{css,scss,sass,less,postcss}\" --fix",
        "lint:all": "pnpm lint:js && pnpm lint:ts && pnpm lint:css && pnpm lint:style",
        "--------------------------------------------------------%": "Testing",
        "jynxio": "node ./src/server/test.ts",
        "gateway": "tsx src/server/gateway.ts"
    },
    "engines": {
        "node": ">=22.17.0",
        "pnpm": ">=9"
    },
    "dependencies": {
        "@babel/runtime": "7.28.6",
        "@base-ui/react": "1.1.0",
        "ai": "6.0.68",
        "core-js": "3.48.0",
        "react": "19.2.4",
        "react-dom": "19.2.4",
        "zod": "4.3.6"
    },
    "devDependencies": {
        "@babel/core": "7.29.0",
        "@babel/plugin-transform-runtime": "7.29.0",
        "@babel/preset-env": "7.29.0",
        "@commitlint/cli": "20.4.1",
        "@commitlint/config-conventional": "20.4.1",
        "@crxjs/vite-plugin": "2.3.0",
        "@eslint/js": "9.39.2",
        "@jynxio/eslint-plugin": "1.0.0",
        "@total-typescript/ts-reset": "0.6.1",
        "@types/chrome": "0.1.36",
        "@types/dom-chromium-ai": "0.0.13",
        "@types/fs-extra": "11.0.4",
        "@types/node": "25.2.0",
        "@types/react": "19.2.10",
        "@types/react-dom": "19.2.3",
        "@typescript-eslint/eslint-plugin": "8.54.0",
        "@typescript-eslint/parser": "8.54.0",
        "@vitejs/plugin-react": "5.1.3",
        "babel-plugin-react-compiler": "1.0.0",
        "browserslist": "4.28.1",
        "esbuild": "0.27.2",
        "eslint": "9.39.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-react": "7.37.5",
        "eslint-plugin-react-hooks": "7.0.1",
        "eslint-plugin-react-refresh": "0.5.0",
        "fs-extra": "11.3.3",
        "globals": "17.3.0",
        "husky": "9.1.7",
        "lightningcss": "1.31.1",
        "lint-staged": "16.2.7",
        "prettier": "3.8.1",
        "stylelint": "17.1.1",
        "stylelint-config-standard": "40.0.0",
        "typescript": "5.9.3",
        "typescript-eslint": "8.54.0",
        "vite": "7.3.1",
        "vite-plugin-zip-pack": "1.2.4"
    }
}
