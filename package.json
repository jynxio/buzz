{
    "name": "buzz",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "ready": "vp fmt && vp lint && vp run test -r && vp run build -r",
        "dev:app": "vp run app#dev",
        "dev:ui": "vp run ui-playground#dev",
        "build:ui": "vp run ui#build",
        "check:ui": "vp run ui#check",
        "prepare": "vp config"
    },
    "devDependencies": {
        "vite-plus": "catalog:"
    },
    "engines": {
        "node": ">=22.12.0"
    },
    "packageManager": "pnpm@10.33.0",
    "pnpm": {
        "onlyBuiltDependencies": [
            "electron",
            "esbuild"
        ]
    }
}
