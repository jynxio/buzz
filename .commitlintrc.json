{
    "extends": ["@commitlint/config-conventional"],
    "rules": {
        "type-enum": [
            2,
            "always",
            ["ci", "chore", "fix", "feat", "perf", "test", "revert", "refactor", "release"]
        ],
        "subject-empty": [2, "never"],
        "scope-empty": [2, "always"],
        "header-max-length": [2, "always", 72],
        "subject-case": [2, "always", ["sentence-case"]]
    }
}
